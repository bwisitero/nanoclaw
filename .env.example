# NanoClaw Environment Configuration
# Copy this file to .env and fill in your values

# Required: Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Required: Web Search API Key
# Get from: https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=

# Optional: Google Workspace Integration (Gmail, Calendar, Drive, Docs, Sheets)
# Get from: https://console.cloud.google.com
# Follow: https://github.com/modelcontextprotocol/servers/tree/main/src/google-workspace
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_REFRESH_TOKEN=

# Optional: Claude Code OAuth (for desktop integration)
CLAUDE_CODE_OAUTH_TOKEN=
